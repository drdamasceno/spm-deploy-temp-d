SUPABASE_URL=https://mkxehqhikcuykaxnpxff.supabase.co
SUPABASE_ANON_KEY=<obter do dashboard Supabase - Settings > API>

# ATENCAO: service_role bypassa RLS. Usado pelo supabase-py em fixtures de teste
# (cria/deleta prestador e rodada). NUNCA commitar o valor real. .env esta no
# .gitignore — mantenha assim.
SUPABASE_SERVICE_ROLE_KEY=<obter do dashboard Supabase - Settings > API>

# Conexao direta ao Postgres do Supabase. Usada pelo T7 via pg8000 para
# disparar UPDATE em rodada aprovada e verificar que o trigger do banco
# bloqueia. Formato: postgresql://postgres:<SENHA>@db.<project>.supabase.co:5432/postgres
# Dashboard Supabase -> Settings -> Database -> Connection string (URI).
# ATENCAO: credencial de superuser. Nunca commitar.
SUPABASE_DB_URL=postgresql://postgres:<SENHA>@db.mkxehqhikcuykaxnpxff.supabase.co:5432/postgres

# Bloco D — gate global de 2FA. Quando true, CEO precisa X-TOTP-Code valido
# e usuario.fa_habilitado=true + usuario.totp_secret preenchido.
FEATURE_2FA=false

# Credenciais para suite de testes do Bloco D (backend/tests/test_*.py).
# Hugo mantem dois usuarios de teste: um com perfil='CEO', outro nao-CEO.
# Se qualquer variavel faltar, a suite pula os testes que dependem dela.
TEST_CEO_EMAIL=
TEST_CEO_PASSWORD=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
